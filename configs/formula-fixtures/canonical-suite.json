{
  "version": 1,
  "cases": [
    { "id": "001_ols_simple", "formula": "y ~ x1 + x2", "allow_random_effects": false,
      "expected": { "outcome": "y", "fixed_effects": ["x1", "x2"], "random_effects": [] } },
    { "id": "002_star_expansion", "formula": "y ~ x1*x2*x3", "allow_random_effects": false,
      "expected": { "outcome": "y", "fixed_effects": ["x1", "x2", "x3", "x1:x2", "x1:x3", "x2:x3", "x1:x2:x3"], "random_effects": [] } },
    { "id": "003_colon_interaction", "formula": "y ~ x1 + x2 + x1:x2", "allow_random_effects": false,
      "expected": { "outcome": "y", "fixed_effects": ["x1", "x2", "x1:x2"], "random_effects": [] } },
    { "id": "008_default_dep", "formula": "x1 + x2", "allow_random_effects": false,
      "expected": { "outcome": "explained_variable", "fixed_effects": ["x1", "x2"], "random_effects": [] } },
    { "id": "009_equals_separator", "formula": "y = x1 + x2", "allow_random_effects": false,
      "expected": { "outcome": "y", "fixed_effects": ["x1", "x2"], "random_effects": [] } },
    { "id": "011_star_two", "formula": "y ~ x1*x2", "allow_random_effects": false,
      "expected": { "outcome": "y", "fixed_effects": ["x1", "x2", "x1:x2"], "random_effects": [] } },
    { "id": "012_mixed_star_colon", "formula": "y ~ a*b + c:d", "allow_random_effects": false,
      "expected": { "outcome": "y", "fixed_effects": ["a", "b", "a:b", "c:d"], "random_effects": [] } },
    { "id": "013_colon_three_way", "formula": "y ~ x1:x2:x3", "allow_random_effects": false,
      "expected": { "outcome": "y", "fixed_effects": ["x1:x2:x3"], "random_effects": [] } },
    { "id": "014_dup_main", "formula": "y ~ x1 + x1 + x2", "allow_random_effects": false,
      "expected": { "outcome": "y", "fixed_effects": ["x1", "x2"], "random_effects": [] } },
    { "id": "015_star_plus_main", "formula": "y ~ x1*x2 + z", "allow_random_effects": false,
      "expected": { "outcome": "y", "fixed_effects": ["x1", "x2", "x1:x2", "z"], "random_effects": [] } },
    { "id": "004_random_intercept", "formula": "y ~ x + (1|g)", "allow_random_effects": true,
      "expected": { "outcome": "y", "fixed_effects": ["x"], "random_effects": ["intercept|g"] } },
    { "id": "005_random_slope_one_var", "formula": "y ~ x + (1+x|g)", "allow_random_effects": true,
      "expected": { "outcome": "y", "fixed_effects": ["x"], "random_effects": ["slope(x)|g"] } },
    { "id": "006_random_slope_multi", "formula": "y ~ x + z + (1+x+z|g)", "allow_random_effects": true,
      "expected": { "outcome": "y", "fixed_effects": ["x", "z"], "random_effects": ["slope(x,z)|g"] } },
    { "id": "007_nested", "formula": "y ~ x + (1|A/B)", "allow_random_effects": true,
      "expected": { "outcome": "y", "fixed_effects": ["x"], "random_effects": ["intercept|A", "intercept|A:B"] } },
    { "id": "010_re_only_no_fixed", "formula": "y ~ (1|g)", "allow_random_effects": true,
      "expected": { "outcome": "y", "fixed_effects": [], "random_effects": ["intercept|g"] } },
    { "id": "016_intercept_and_slope_same_group", "formula": "y ~ x + (1|g) + (1+x|g)",
      "error": "duplicate grouping variable" },
    { "id": "017_two_groups", "formula": "y ~ x + (1|g) + (1|h)", "allow_random_effects": true,
      "expected": { "outcome": "y", "fixed_effects": ["x"], "random_effects": ["intercept|g", "intercept|h"] } },
    { "id": "018_star_with_re", "formula": "y ~ x1*x2 + (1|g)", "allow_random_effects": true,
      "expected": { "outcome": "y", "fixed_effects": ["x1", "x2", "x1:x2"], "random_effects": ["intercept|g"] } },
    { "id": "019_nested_with_fixed", "formula": "y ~ x + z + (1|school/class)", "allow_random_effects": true,
      "expected": { "outcome": "y", "fixed_effects": ["x", "z"], "random_effects": ["intercept|school", "intercept|school:class"] } },
    { "id": "020_slope_on_interaction_var", "formula": "y ~ x1 + x2 + x1:x2 + (1+x1|g)", "allow_random_effects": true,
      "expected": { "outcome": "y", "fixed_effects": ["x1", "x2", "x1:x2"], "random_effects": ["slope(x1)|g"] } },
    { "id": "021_multivar_slope_and_intercept", "formula": "y ~ x + z + (1|g) + (1+x+z|h)", "allow_random_effects": true,
      "expected": { "outcome": "y", "fixed_effects": ["x", "z"], "random_effects": ["slope(x,z)|h", "intercept|g"] } },
    { "id": "022_implicit_intercept_slope", "formula": "y ~ x + (x|g)", "allow_random_effects": true,
      "expected": { "outcome": "y", "fixed_effects": ["x"], "random_effects": ["slope(x)|g"] } },
    { "id": "err_empty", "formula": "", "error": "formula is empty" },
    { "id": "err_bad_identifier", "formula": "y ~ 1x", "error": "formula syntax error" },
    { "id": "err_duplicate_group", "formula": "y ~ x + (1|g) + (1|g)", "error": "duplicate grouping variable" },
    { "id": "err_term_removal", "formula": "y ~ x1 - x2", "error": "term removal" },
    { "id": "err_intercept_suppression_zero", "formula": "y ~ x + (0+x|g)", "error": "intercept suppression" },
    { "id": "err_intercept_suppression_minus_one", "formula": "y ~ x + (-1+x|g)", "error": "intercept suppression" }
  ]
}

{
  "outcomeKind": "continuous",
  "config": {
    "family": "anova",
    "formula": "life_satisfaction = region",
    "variables": [
      { "name": "region", "kind": "factor", "nLevels": 3, "levelProportions": [1, 1, 1], "role": "factor" }
    ],
    "effects": [
      { "name": "region[2]", "value": 0.5 },
      { "name": "region[3]", "value": 0.5 }
    ],
    "correlations": [],
    "targetPower": 80,
    "alpha": 0.05,
    "tests": { "kind": "effects", "names": [] },
    "reportOverall": true,
    "contrasts": [
      { "positiveName": "region[2]", "negativeName": "region[3]", "enabled": true }
    ],
    "findPower": { "n": 150 },
    "findSampleSize": { "from": 30, "to": 200, "by": "auto" },
    "advanced": {
      "simulations": 1600,
      "seed": 2137,
      "correction": "none",
      "maxFailedSimulations": 0.1,
      "testFormulaOverride": ""
    }
  }
}

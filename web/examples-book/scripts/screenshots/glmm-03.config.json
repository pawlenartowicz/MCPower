{
  "outcomeKind": "binary",
  "config": {
    "family": "mixed",
    "formula": "employed = policy_group * period + (1|individual)",
    "variables": [
      { "name": "policy_group", "kind": "binary", "binaryProportion": 0.5 },
      { "name": "period", "kind": "continuous" }
    ],
    "effects": [
      { "name": "policy_group", "value": 0.5 },
      { "name": "period", "value": 0.25 },
      { "name": "policy_group:period", "value": 0.5 }
    ],
    "correlations": [],
    "targetPower": 80,
    "alpha": 0.05,
    "tests": { "kind": "all" },
    "reportOverall": true,
    "contrasts": [],
    "findPower": { "n": 240 },
    "findSampleSize": { "from": 30, "to": 200, "by": "auto" },
    "advanced": {
      "simulations": 800,
      "seed": 2137,
      "correction": "none",
      "maxFailedSimulations": 0.1,
      "testFormulaOverride": ""
    },
    "cluster": {
      "clusterName": "individual",
      "icc": 0.2,
      "dimKind": "n_clusters",
      "nClusters": 40,
      "clusterSize": 30,
      "binaryOutcome": true,
      "baselineProbability": 0.3,
      "extraGroupings": [],
      "slopes": []
    }
  }
}

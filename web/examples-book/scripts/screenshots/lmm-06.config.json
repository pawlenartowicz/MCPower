    "effects": [
      { "name": "treatment", "value": 0.5 },
      { "name": "baseline_bp", "value": 0.4 }
    ],
    "correlations": [],
    "targetPower": 80,
    "alpha": 0.05,
    "tests": { "kind": "all" },
    "reportOverall": true,
    "contrasts": [],
    "findPower": { "n": 300 },
    "findSampleSize": { "from": 30, "to": 200, "by": "auto" },
    "advanced": {
      "simulations": 800,
      "seed": 2137,
      "correction": "none",
      "maxFailedSimulations": 0.1,
      "testFormulaOverride": ""
    },
    "cluster": {
      "clusterName": "clinic",
      "icc": 0.1,
      "dimKind": "n_clusters",
      "nClusters": 30,
      "clusterSize": 10,
      "extraGroupings": [],
      "slopes": []
    }
  }
}

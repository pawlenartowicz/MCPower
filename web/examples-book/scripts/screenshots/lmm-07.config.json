{
  "outcomeKind": "continuous",
  "config": {
    "family": "mixed",
    "formula": "recovery_days = treatment + (treatment | site)",
    "variables": [
      { "name": "treatment", "kind": "binary", "binaryProportion": 0.5 }
    ],
    "effects": [
      { "name": "treatment", "value": 0.5 }
    ],
    "correlations": [],
    "targetPower": 80,
    "alpha": 0.05,
    "tests": { "kind": "all" },
    "reportOverall": true,
    "contrasts": [],
    "findPower": { "n": 300 },
    "findSampleSize": { "from": 30, "to": 200, "by": "auto" },
    "advanced": {
      "simulations": 800,
      "seed": 2137,
      "correction": "none",
      "maxFailedSimulations": 0.1,
      "testFormulaOverride": ""
    },
    "cluster": {
      "clusterName": "site",
      "icc": 0.1,
      "dimKind": "n_clusters",
      "nClusters": 30,
      "clusterSize": 30,
      "clusterLevelVars": ["treatment"],
      "extraGroupings": [],
      "slopes": [
        { "predictorName": "treatment", "slopeVariance": 0.05, "slopeInterceptCorr": 0.0 }
      ]
    }
  }
}
